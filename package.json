{
  "name": "crev-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "SMOKE=1 vitest run packages/runtimes/src/smoke.test.ts",
    "crev": "pnpm --filter @crev/runtimes build --silent && tsx packages/cli/src/bin.ts"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "tsup": "^8.4.0",
    "tsx": "4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.8.0"
}
