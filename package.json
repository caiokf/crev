{
  "name": "@caiokf/crev",
  "version": "0.2.2",
  "type": "module",
  "bin": {
    "crev": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "tsup",
    "crev": "tsup --silent && tsx src/bin.ts"
  },
  "dependencies": {
    "@caiokf/valet": "^0.1.1",
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "glob": "13.0.6",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "tsup": "^8.4.0",
    "tsx": "4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.8.0"
}
